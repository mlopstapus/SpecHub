# Copy to .env and fill in real values. .env is gitignored.

# Runtime app role connection string — least-privileged, subject to RLS.
# NEVER point this at the schema-owning/migration role (see context/database-conventions.md).
DATABASE_URL=postgresql://REPLACE_ME_APP_ROLE:REPLACE_ME_PASSWORD@localhost:5432/skillcanon

# Migration/owner role connection string — used only by `pnpm db:migrate` / `pnpm db:generate`.
# Owns the seven bounded-context schemas; RLS does not apply to this role.
MIGRATION_DATABASE_URL=postgresql://REPLACE_ME_OWNER_ROLE:REPLACE_ME_PASSWORD@localhost:5432/skillcanon

# Credential-resolution/tenant-bootstrap role connection string — used only by
# identity-access flows that must run before any organization context exists
# (login, session/API-key authentication, invitation acceptance, and
# organization/team/admin bootstrap). Scoped to the identity_access schema
# only (SELECT/INSERT/UPDATE, no DELETE) — narrower than the migration/owner
# role above (see context/database-conventions.md).
AUTH_DATABASE_URL=postgresql://REPLACE_ME_AUTH_ROLE:REPLACE_ME_PASSWORD@localhost:5432/skillcanon

# HS256 signing key for session JWTs (see context/auth-conventions.md). The app
# refuses to start real work if this is missing or still equals a placeholder.
JWT_SECRET=REPLACE_ME_JWT_SECRET

# Session lifetime in hours. No refresh flow at launch — an expired session
# requires a full re-login (context/auth-conventions.md).
JWT_EXPIRY_HOURS=24

# Invitation token lifetime in hours (default 7 days).
INVITATION_EXPIRY_HOURS=168

# Base URL used to build invitation links (e.g. APP_BASE_URL/invite/<token>).
APP_BASE_URL=http://localhost:3000

# Generic SMTP config for sending real email (invitations, etc.) — see
# context/third-party-services.md. Self-hosted installs may leave these unset;
# email delivery is then skipped with a log line instead of failing. The
# managed SaaS uses SES instead (not yet wired — see that document's
# Implementation status section), so these are not required there either.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=SkillCanon <no-reply@example.com>
